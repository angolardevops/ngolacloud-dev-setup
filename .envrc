# =============================================================================
# .envrc — direnv per-project env template for ngolacloud projects
# =============================================================================
# Works two ways:
#   1. `direnv allow`     — recommended; auto-loads/unloads when cd-ing
#   2. `source .envrc`    — manual; fallback shims defined below so
#                            PATH_add and source_env still work
# =============================================================================

# ── Fallback shims when sourced WITHOUT direnv ────────────────────────────
if ! type -t PATH_add >/dev/null 2>&1; then
  PATH_add() { case ":$PATH:" in *":$1:"*) ;; *) export PATH="$1:$PATH" ;; esac; }
fi
if ! type -t source_env >/dev/null 2>&1; then
  source_env() { [ -f "$1" ] && . "$1"; }
fi

# ── Kubernetes ────────────────────────────────────────────────────────────
export KUBECONFIG="$HOME/.kube/config"
export KIND_CLUSTER="ngolacloud-dev"
# Pin kubectl to the dev cluster context so accidental `kubectl apply` can't
# hit production:
kubectl config use-context "kind-$KIND_CLUSTER" 2>/dev/null || true

# ── Rust ──────────────────────────────────────────────────────────────────
export RUSTC_WRAPPER="/usr/local/bin/sccache"
export CARGO_INCREMENTAL=0   # sccache works better with incremental off
export CARGO_TARGET_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/cargo-target/$(basename "$PWD")"
mkdir -p "$CARGO_TARGET_DIR"

# ── Go (some ngolacloud projects use both) ────────────────────────────────
export GOFLAGS="-mod=readonly"
export GOCACHE="${XDG_CACHE_HOME:-$HOME/.cache}/go-build"

# ── NgolaCloud CLI ────────────────────────────────────────────────────────
# Set this if the project ships a .ngolacloud.toml for the dev cluster:
# export NGOLACLOUD_TOML="$PWD/.ngolacloud.toml"

# ── Secrets ───────────────────────────────────────────────────────────────
# Source a non-committed file for tokens / API keys. Add `*.secret` to
# .gitignore in the project to keep this safe.
if [ -f .envrc.secret ]; then
  source_env .envrc.secret
fi

# ── PATH ──────────────────────────────────────────────────────────────────
# Project-local bins (if you keep build outputs in ./bin or ./target/release)
PATH_add "$PWD/target/release"
PATH_add "$PWD/bin"
