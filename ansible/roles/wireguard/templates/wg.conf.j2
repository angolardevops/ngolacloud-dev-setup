# =============================================================================
# /etc/wireguard/{{ wg_interface }}.conf
# Generated by ngolacloud-dev-setup. Re-run `make setup TAGS=wireguard` to update.
# =============================================================================
[Interface]
PrivateKey = {{ wg_private_key }}
Address    = {{ wg_local_address }}
{% if wg_listen_port | int > 0 %}
ListenPort = {{ wg_listen_port }}
{% endif %}
{% if wg_local_dns %}
DNS        = {{ wg_local_dns }}
{% endif %}

# Save-and-restore the routing table so reboots leave a clean state.
SaveConfig = false

[Peer]
PublicKey           = {{ wg_remote_pubkey }}
Endpoint            = {{ wg_remote_endpoint }}
AllowedIPs          = {{ wg_allowed_ips }}
{% if wg_persistent_keepalive | int > 0 %}
PersistentKeepalive = {{ wg_persistent_keepalive }}
{% endif %}
